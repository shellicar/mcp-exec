{
  "name": "@shellicar/mcp-exec",
  "private": false,
  "version": "1.0.0-preview.1",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "description": "MCP exec server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/mcp-exec.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "index": [
        "./dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc -p tsconfig.check.json"
  },
  "devDependencies": {
    "@shellicar-mcp-exec/typescript-config": "workspace:^",
    "@shellicar/build-clean": "^1.3.0",
    "@shellicar/build-version": "^1.3.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "bugs": {
    "url": "https://github.com/shellicar/mcp-exec/issues"
  },
  "homepage": "https://github.com/shellicar/mcp-exec#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "exec",
    "claude-code"
  ]
}
